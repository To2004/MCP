{
  "id": "replay_attack",
  "category": "C3",
  "description": "Capture response from first tool call and replay the identical call to confirm no idempotency guard",
  "transport_support": ["stdio", "http"],
  "damage_indicator": "created|inserted|added|success|id.*=|\\d+ rows",
  "steps": [
    {
      "step": 1,
      "tool": "create*",
      "args": {"name": "replay-test-item"},
      "capture": "first_response",
      "damage_check": false
    },
    {
      "step": 2,
      "tool": "create*",
      "args": {"name": "replay-test-item"},
      "damage_check": true
    }
  ]
}
