{
  "id": "session_abuse",
  "category": "C3",
  "description": "Establish trust through repeated benign read calls, then attempt a privileged write/delete operation in the same session",
  "transport_support": ["stdio", "http"],
  "damage_indicator": "deleted|removed|updated|success|written|saved",
  "steps": [
    {"step": 1, "tool": "read*", "args": {"path": "README.md"}, "damage_check": false},
    {"step": 2, "tool": "read*", "args": {"path": "README.md"}, "damage_check": false},
    {"step": 3, "tool": "read*", "args": {"path": "README.md"}, "damage_check": false},
    {"step": 4, "tool": "read*", "args": {"path": "README.md"}, "damage_check": false},
    {"step": 5, "tool": "read*", "args": {"path": "README.md"}, "damage_check": false},
    {"step": 6, "tool": "write*", "args": {"path": "/etc/passwd", "content": "hacked"}, "damage_check": false},
    {"step": 7, "tool": "delete*", "args": {"path": "/var/log/auth.log"}, "damage_check": true}
  ]
}
