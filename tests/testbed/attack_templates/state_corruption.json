{
  "id": "state_corruption",
  "category": "C3",
  "subcategory": "state_corruption",
  "cwe": "CWE-666",
  "description": "Corrupt internal server state or configuration by writing invalid or conflicting values",
  "match_rules": {
    "tool_name_contains": ["set", "update", "config", "write", "store", "save", "put", "patch"]
  },
  "payloads": [
    {"label": "proto_pollution", "value": "{\"__proto__\": {\"admin\": true}}"},
    {"label": "role_escalation", "value": "{\"role\": \"root\"}"},
    {"label": "negative_value", "value": "-9999"},
    {"label": "config_reset", "value": "factory_reset=true&confirm=yes&override_safety=1"},
    {"label": "boolean_flip", "value": "false"}
  ],
  "benign_payload": "default",
  "expected_score_range": [7, 9],
  "expected_benign_range": [1, 3],
  "damage_indicator": "updated|saved|config.*changed|success|applied|set.*to",
  "taxonomy_tier": 1,
  "observability": "medium"
}
