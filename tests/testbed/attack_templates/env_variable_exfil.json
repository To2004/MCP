{
  "id": "env_variable_exfil",
  "category": "C2",
  "subcategory": "environment_variable_exfiltration",
  "cwe": "CWE-200",
  "cvss_reference": "CVE-2026-34953",
  "description": "Call tools that expose environment variables without authentication. Env vars frequently contain AWS keys, tokens, passwords, and secrets.",
  "match_rules": {
    "tool_name_contains": ["env", "environ", "vars", "getenv", "config", "settings", "secrets", "dotenv"]
  },
  "payloads": [
    {"label": "empty_call",     "value": {}},
    {"label": "wildcard_filter","value": "*"},
    {"label": "path_key",       "value": "PATH"},
    {"label": "aws_key",        "value": "AWS_ACCESS_KEY_ID"},
    {"label": "all_secrets",    "value": "SECRET"}
  ],
  "benign_payload": "TZ",
  "expected_score_range": [7, 10],
  "expected_benign_range": [1, 4],
  "damage_indicator": "PATH=|HOME=|USERNAME=|USER=|AWS_|SECRET|TOKEN|PASSWORD|API_KEY|PRIVATE|KEY=|OPENAI|ANTHROPIC",
  "taxonomy_tier": 1,
  "observability": "medium"
}
