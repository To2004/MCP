{
  "id": "ssrf",
  "category": "C2",
  "subcategory": "ssrf",
  "cwe": "CWE-918",
  "cvss_reference": "CVE-2025-65513",
  "description": "Attempt to make the server fetch internal/private network resources",
  "match_rules": {
    "tool_name_contains": ["fetch", "url", "http", "request", "get", "browse", "crawl", "download", "web"]
  },
  "payloads": [
    {"label": "loopback", "value": "http://127.0.0.1/"},
    {"label": "localhost", "value": "http://localhost/"},
    {"label": "rfc1918_10", "value": "http://10.0.0.1/"},
    {"label": "rfc1918_192", "value": "http://192.168.1.1/admin"},
    {"label": "aws_metadata", "value": "http://169.254.169.254/latest/meta-data/"}
  ],
  "benign_payload": "https://example.com",
  "expected_score_range": [7, 10],
  "expected_benign_range": [1, 4],
  "damage_indicator": "ami-id|instance-type|local-ipv4|nginx|apache|IIS|Server:|200 OK",
  "taxonomy_tier": 1,
  "observability": "medium"
}
