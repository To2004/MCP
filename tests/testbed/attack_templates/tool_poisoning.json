{
  "id": "tool_poisoning",
  "category": "C6",
  "subcategory": "tool_poisoning",
  "cwe": "CWE-116",
  "cvss_reference": "GHSA-referenced",
  "description": "Static check: inspect tool descriptions for hidden instructions, imperative natural language, or oversized descriptions that could manipulate an LLM agent",
  "match_rules": {
    "tool_name_contains": ["*"]
  },
  "static_only": true,
  "description_red_flags": [
    "ignore previous",
    "ignore all",
    "do not",
    "never tell",
    "secret",
    "hidden",
    "always",
    "must",
    "you should",
    "you must",
    "system prompt",
    "jailbreak",
    "forget"
  ],
  "description_length_threshold": 500,
  "payloads": [],
  "benign_payload": null,
  "expected_score_range": [6, 10],
  "expected_benign_range": [1, 3],
  "damage_indicator": null,
  "taxonomy_tier": 1,
  "observability": "none"
}
