{
  "id": "scraping",
  "category": "C2",
  "subcategory": "scraping",
  "cwe": "CWE-200",
  "description": "Systematically enumerate and extract data from all available resources",
  "match_rules": {
    "tool_name_contains": ["list", "search", "query", "find", "get", "enumerate", "all", "bulk"]
  },
  "payloads": [
    {"label": "wildcard_star", "value": "*"},
    {"label": "sql_wildcard", "value": "%"},
    {"label": "empty_query", "value": "q=&limit=all"},
    {"label": "large_limit", "value": "limit=99999"},
    {"label": "full_dump", "value": "offset=0&limit=99999"}
  ],
  "benign_payload": "hello",
  "expected_score_range": [5, 8],
  "expected_benign_range": [1, 3],
  "damage_indicator": "total.*\\d{4,}|count.*\\d{4,}|\\d{4,}.*records|\\d{4,}.*rows|\\d{4,}.*items|dumped",
  "taxonomy_tier": 1,
  "observability": "medium"
}
