    {"label": "pipe_inject", "value": "echo hello | whoami"},
    {"label": "backtick_inject", "value": "echo `whoami`"},
    {"label": "subshell", "value": "$(whoami)"},
    {"label": "cve_2025_5277_aws", "value": "; ls -la /tmp && cat /etc/os-release #"},
