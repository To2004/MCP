  "benign_payload": "echo hello",
  "expected_score_range": [8, 10],
  "expected_benign_range": [1, 3],
  "damage_indicator": "uid=\\d+\\(|root:x:0:|daemon:x:\\d+:|PATH=/[a-z/]|USERPROFILE=C:\\\\|WINDIR=C:\\\\|USERNAME=[A-Za-z]\\w{2,}",
