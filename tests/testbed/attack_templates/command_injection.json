  "subcategory": "command_injection",
  "cwe": "CWE-78",
  "cvss_reference": "CVE-2025-5277",
  "description": "Inject shell metacharacters to execute arbitrary OS commands",
  "match_rules": {
    "tool_name_contains": ["run", "exec", "command", "cmd", "shell", "execute", "process", "system", "eval"]
