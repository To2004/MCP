# Default: normalize line endings to LF in repo, checkout native on Windows
* text=auto eol=lf

# Explicit text files
*.py      text eol=lf
*.md      text eol=lf
*.toml    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.txt     text eol=lf
*.sh      text eol=lf
*.tex     text eol=lf
*.bib     text eol=lf

# Binary (prevent line-ending mangling)
*.pdf     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.xlsx    binary
*.xls     binary
*.docx    binary
*.doc     binary
*.pptx    binary
*.ppt     binary
*.zip     binary
*.gz      binary
